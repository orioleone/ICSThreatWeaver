# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default): sqlite:///./ics_threatweaver.db
# PostgreSQL:       postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./ics_threatweaver.db

# ── MITRE ATT&CK ─────────────────────────────────────────────────────────────
MITRE_ICS_URL=https://raw.githubusercontent.com/mitre/cti/master/ics-attack/ics-attack.json
# Space-separated list of hostnames allowed as import targets (SSRF guard)
# MITRE_ALLOWED_HOSTS=raw.githubusercontent.com github.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins.  Use ["*"] only on isolated hosts.
# CORS_ORIGINS=http://localhost:8000 http://127.0.0.1:8000

# ── Authentication ────────────────────────────────────────────────────────────
# Set a strong random value to enable API-key auth on all write endpoints.
# Leave blank to run without auth (local development only).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Maximum API requests per IP per window.
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=60

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
